# ===== API configuration ===== (copy to apps/api/.env and fill in)

# Supabase project
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_REF=YOUR_PROJECT_REF

# Browser-safe anon key (used to verify staff JWTs)
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# SECRET — server only. Bypasses RLS. Never expose to a browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Optional: Postgres password / management token (only if you use them locally)
SUPABASE_DB_PASSWORD=
SUPABASE_ACCESS_TOKEN=

# API server
PORT=4000
# Comma-separated allowed origins (admin + public dev/prod URLs)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
